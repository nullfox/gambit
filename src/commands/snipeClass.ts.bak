const getChainConfiguration = (name: string) => {
  const ChainConfigurationPath = join(PATH_CHAINS_DIR, `${name}.json`);

  if (!existsSync(ChainConfigurationPath)) {
    throw new Error(
      `Could not open chain cnfig file "${ChainConfigurationPath}" - please ensure it exists`,
    );
  }

  const contents = readFileSync(ChainConfigurationPath).toString();

  return JSON.parse(contents) as ChainConfiguration;
};

const getClients = (rpcs: string[], wss?: string) => ({
  primary: new Web3(new Web3.providers.HttpProvider(rpcs[0])),
  secondary: new Web3(new Web3.providers.HttpProvider(rpcs[1] || rpcs[0])),
  socket: wss
    ? new Web3(
        new Web3.providers.WebsocketProvider(wss, {
          timeout: 30000,
          clientConfig: {
            maxReceivedFrameSize: 100000000,
            maxReceivedMessageSize: 100000000,
          },
          reconnect: {
            auto: true,
            delay: 5000,
            maxAttempts: 15,
            onTimeout: false,
          },
        }),
      )
    : undefined,
});

const getDex = async (
  web3: Web3,
  account: string,
  chain: string,
  dex: string,
) => {
  const contents = readFileSync(PATH_SWAPS).toString();

  const swaps: Swaps = JSON.parse(contents);

  const swap = swaps.routers.find(
    (sw) => sw.chain.toLowerCase() === chain && sw.name.toLowerCase() === dex,
  );

  if (!swap) {
    throw new Error(`Could not find DEX named "${dex}" on chain "${chain}"`);
  }

  const router = new web3.eth.Contract(swap.routerABI, swap.routerAddress, {
    from: account,
  });

  let factoryAddress = swap.factoryAddress;

  if (!factoryAddress || factoryAddress.length === 0) {
    factoryAddress = await router.methods.factory().call();
  }

  const factory = new web3.eth.Contract(swap.factoryABI, factoryAddress);

  return {
    router,
    factory,
    pairContractAbi: swap.pairContractABI,
    routerName: swap.name,
    routerAddress: swap.routerAddress,
  };
};

