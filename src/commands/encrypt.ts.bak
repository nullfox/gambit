import { existsSync, readFileSync, unlinkSync, writeFileSync } from 'fs';
import { join } from 'path';
import {
  WALLET_EXTENSION_ENCRYPTED,
  WALLET_EXTENSION_RAW,
} from '../constants.js';
import Crypt from '../services/crypt.js';

const encrypt = (walletName: string, password: string, force?: boolean) => {
  const inPath = join(process.cwd(), `${walletName}.${WALLET_EXTENSION_RAW}`);
  const outPath = join(
    process.cwd(),
    `${walletName}.${WALLET_EXTENSION_ENCRYPTED}`,
  );

  if (!existsSync(inPath)) {
    throw new Error(
      `Could not open file "${inPath}" - please ensure it exists`,
    );
  }

  if (existsSync(outPath)) {
    if (!force) {
      throw new Error(`Output file "${outPath}" - already exists`);
    }

    unlinkSync(outPath);
  }

  const wallet = readFileSync(inPath).toString('utf-8');

  const crypt = new Crypt(password);

  const encryptedWallet = crypt.encrypt(wallet);

  writeFileSync(
    outPath,
    Buffer.from(JSON.stringify(encryptedWallet)).toString('binary'),
  );

  unlinkSync(inPath);

  return outPath;
};

export default encrypt;
